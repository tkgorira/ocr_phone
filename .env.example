# ── データベース ─────────────────────────────────────────────────────────────
# ローカル PostgreSQL (Raspberry Pi / 開発環境)
DATABASE_URL=postgresql://appuser:password@localhost:5432/appdb
# Neon / Render などのクラウド環境の場合:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# DATABASE_SSL=true  # クラウド環境で pg が SSL を使う場合に設定

# ── JWT ────────────────────────────────────────────────────────────────────
# ランダムな長い文字列を設定してください (例: openssl rand -hex 32)
JWT_SECRET=your-random-secret-key-here

# ── Stripe ─────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Dashboard > 製品 > 価格ID (例: price_xxx)
STRIPE_PRICE_ID=price_...

# Stripe Dashboard > 開発者 > Webhook > シークレット
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Apple Pay ドメイン検証 ──────────────────────────────────────────────────
APPLE_PAY_DOMAIN_ASSOC=

# ── アプリURL ───────────────────────────────────────────────────────────────
APP_URL=https://your-app.onrender.com

# ── ポート ────────────────────────────────────────────────────────────────
PORT=3000
