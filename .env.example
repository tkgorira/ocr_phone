# ── データベース (Neon PostgreSQL) ──────────────────────────────────────────
# https://neon.tech で無料アカウントを作成し、接続文字列をコピーしてください
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT ────────────────────────────────────────────────────────────────────
# ランダムな長い文字列を設定してください (例: openssl rand -hex 32)
JWT_SECRET=your-random-secret-key-here

# ── Stripe ─────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Dashboard > 製品 > 価格ID (例: price_xxx)
STRIPE_PRICE_ID=price_...

# Stripe Dashboard > 開発者 > Webhook > シークレット
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Apple Pay ドメイン検証 ──────────────────────────────────────────────────
# Stripe Dashboard > 設定 > 支払い方法 > Apple Pay > ドメイン登録
# そこに表示されるファイルの内容をそのまま1行で貼り付けてください
APPLE_PAY_DOMAIN_ASSOC=

# ── アプリURL ───────────────────────────────────────────────────────────────
# Stripe の返却先URL に使用します
APP_URL=https://your-app.onrender.com

# ── ポート (Renderが自動設定) ──────────────────────────────────────────────
PORT=3001
